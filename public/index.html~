<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NFT Scanner</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #080c14; color: #fff; font-family: system-ui, sans-serif; padding: 20px; }
  h1 { color: #00ff88; font-family: monospace; margin-bottom: 20px; }
  .card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
  .name { font-weight: 700; font-size: 16px; margin-bottom: 8px; }
  .stats { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .stat { background: rgba(255,255,255,0.04); border-radius: 8px; padding: 8px; }
  .stat-label { font-size: 10px; color: rgba(255,255,255,0.4); }
  .stat-value { font-size: 14px; font-weight: 700; font-family: monospace; }
  .score { float: right; font-size: 28px; font-weight: 800; font-family: monospace; }
  button { background: rgba(0,255,136,0.12); border: 1px solid rgba(0,255,136,0.3); color: #00ff88; padding: 10px 20px; border-radius: 10px; font-weight: 700; cursor: pointer; margin-bottom: 20px; }
  .log { font-family: monospace; font-size: 11px; color: rgba(255,255,255,0.4); margin-bottom: 16px; }
</style>
</head>
<body>
<h1>NFT / Scanner <span style="font-size:12px;background:rgba(0,255,136,0.12);padding:2px 8px;border-radius:20px;">LIVE</span></h1>
<button onclick="loadData()">🔄 Refresh</button>
<div class="log" id="log"></div>
<div id="cards"></div>
<script>
const COLLECTIONS = [
  { name: "Pudgy Penguins", slug: "pudgypenguins",    chain: "⟠" },
  { name: "Azuki",          slug: "azuki",             chain: "⟠" },
  { name: "Milady Maker",   slug: "milady-maker",      chain: "⟠" },
  { name: "Bored Ape YC",   slug: "boredapeyachtclub", chain: "⟠" },
  { name: "Mad Lads",       slug: "mad-lads",          chain: "◎" },
  { name: "DeGods",         slug: "degods",            chain: "◎" },
];

function log(msg) {
  document.getElementById("log").innerHTML += msg + "<br>";
}

function score(vol, change, sales) {
  const v = Math.min(100, (vol/500)*100);
  const f = Math.min(100, Math.max(0, ((change+15)/55)*100));
  const s = Math.min(100, (sales/300)*100);
return Math.round(v*0.3 + f*0.25 + s*0.15 + 50*0.3);
}

function color(s) {
  return s >= 70 ? "#00ff88" : s >= 45 ? "#ffcc00" : "#ff4466";
}

async function loadData() {
  document.getElementById("log").innerHTML = "";
  document.getElementById("cards").innerHTML = "";
  log("🔄 Avvio fetch...");
  for (const col of COLLECTIONS) {
    try {
      log("📡 " + col.name + "...");
      const res = await fetch("/api/opensea/" + col.slug + "/stats");
      const data = await res.json();
      const total = data.total ?? {};
      const day = (data.intervals ?? []).find(i => i.interval === "one_day") ?? {};
      const floor = (total.floor_price ?? 0).toFixed(3);
      const vol = (day.volume ?? 0).toFixed(2);
      const sales = day.sales ?? 0;
      const change = (day.volume_change ?? 0).toFixed(1);
      const holders = (total.num_owners ?? 0).toLocaleString();
      const s = score(parseFloat(vol), parseFloat(change), sales);
      const c = color(s);
      log("✅ " + col.name + ": " + floor + " ETH");
      document.getElementById("cards").innerHTML += `
        <div class="card">
<div class="score" style="color:${c}">${s}</div>
          <div class="name">${col.chain} ${col.name}</div>
          <div class="stats">
            <div class="stat"><div class="stat-label">Floor</div><div class="stat-value">${floor} ETH</div></div>
            <div class="stat"><div class="stat-label">Volume 24h</div><div class="stat-value">${vol} ETH</div></div>
            <div class="stat"><div class="stat-label">Sales 24h</div><div class="stat-value">${sales}</div></div>
            <div class="stat"><div class="stat-label">Holders</div><div class="stat-value">${holders}</div></div>
            <div class="stat"><div class="stat-label">24h Δ</div><div class="stat-value" style="color:${parseFloat(change)>=0?'#00ff88':'#ff4466'}">${change}%</div></div>
          </div>
        </div>`;
    } catch(e) {
      log("❌ " + col.name + ": " + e.message);
}
  }
}
loadData();
</script>
</body>
</html>
